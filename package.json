{
  "name": "n8n-nodes-spectrum",
  "version": "1.0.0",
  "description": "n8n community node for Photon Spectrum - inbound text webhooks and iMessage send/reply/react/typing/group",
  "license": "MIT",
  "keywords": [
    "n8n-community-node-package",
    "spectrum",
    "photon",
    "n8n",
    "automation",
    "messaging",
    "imessage"
  ],
  "author": {
    "name": "Photon AI",
    "email": "vandit@photon.codes",
    "url": "https://photon.codes"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/photon-hq/n8n-nodes-spectrum.git"
  },
  "homepage": "https://github.com/photon-hq/n8n-nodes-spectrum#readme",
  "bugs": {
    "url": "https://github.com/photon-hq/n8n-nodes-spectrum/issues"
  },
  "engines": {
    "node": ">=20.15.0"
  },
  "scripts": {
    "build": "n8n-node build && node scripts/bundle-spectrum.mjs && node scripts/prune-dist.mjs",
    "dev": "node scripts/dev-with-tunnel.mjs",
    "dev:local": "NO_TUNNEL=1 node scripts/dev-with-tunnel.mjs",
    "dev:tunnel": "node scripts/dev-with-tunnel.mjs",
    "link:dev": "node scripts/link-dev-package.mjs",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "scan": "n8n-node build && node scripts/prune-dist.mjs && node scripts/scan-local.mjs",
    "verify": "npm run lint && npm run build && npm run scan && node scripts/verify-english.mjs",
    "verify:english": "node scripts/verify-english.mjs",
    "release": "n8n-node release",
    "prepublishOnly": "node scripts/generate-shrinkwrap.mjs && n8n-node prerelease"
  },
  "files": [
    "dist",
    "npm-shrinkwrap.json"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/PhotonSpectrumCloudApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/PhotonSpectrum/PhotonSpectrum.node.js",
      "dist/nodes/PhotonSpectrumTrigger/PhotonSpectrumTrigger.node.js",
      "dist/nodes/PhotonSpectrumTyping/PhotonSpectrumTyping.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "@n8n/scan-community-package": "*",
    "esbuild": "^0.28.0",
    "eslint": "9.32.0",
    "prettier": "3.6.2",
    "spectrum-ts": "^1.9.1",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "publishConfig": {
    "access": "public"
  }
}
